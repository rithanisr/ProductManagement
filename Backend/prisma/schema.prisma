generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  VENDOR
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
}

model User {
  id         Int    @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  role       Role
  createdAt  DateTime @default(now())
  products  Product[]
  orders    Order[]
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  price       Float
  stock       Int
  description String
  status      ProductStatus
  imageUrl    String?

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  vendorId    Int?
  vendor      User? @relation(fields: [vendorId], references: [id])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique

  products Product[]
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  total     Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int
  order       Order  @relation(fields: [orderId], references: [id])
  productId   Int
  productName String
  quantity    Int
  unitPrice   Float
}